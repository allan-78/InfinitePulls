{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "credentialsSource": "local",
      "env": {
        "EXPO_USE_COMMUNITY_AUTOLINKING": "1"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "credentialsSource": "local",
      "env": {
        "EXPO_USE_COMMUNITY_AUTOLINKING": "1"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "env": {
        "EXPO_USE_COMMUNITY_AUTOLINKING": "1"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
